[
  {
    "start": 0.0,
    "end": 3.5,
    "text": "日本地図の歌",
    "kana": "にほんちずのうた",
    "romaji": "nihon chizu no uta",
    "zh": "日本地圖之歌"
  },
  {
    "start": 7.0,
    "end": 10.5,
    "text": "北から順番に覚えましょう。",
    "kana": "きたからじゅんばんにおぼえましょう。",
    "romaji": "kita kara junban ni oboemashou",
    "zh": "從北開始依序記吧。"
  },
  {
    "start": 10.5,
    "end": 13.5,
    "text": "札幌ラーメン、北海道。",
    "kana": "さっぽろラーメン、ほっかいどう。",
    "romaji": "sapporo raamen, hokkaidou",
    "zh": "札幌拉麵，北海道。"
  },
  {
    "start": 13.5,
    "end": 17.5,
    "text": "りんごがおいしい、青森県。",
    "kana": "りんごがおいしい、あおもりけん。",
    "romaji": "ringo ga oishii, aomori ken",
    "zh": "蘋果很好吃，青森縣。"
  },
  {
    "start": 17.5,
    "end": 20.5,
    "text": "わんこの盛岡、岩手県。",
    "kana": "わんこのもりおか、いわてけん。",
    "romaji": "wanko no morioka, iwate ken",
    "zh": "わんこの盛岡，岩手縣。"
  },
  {
    "start": 20.5,
    "end": 24.5,
    "text": "牛タン仙台、宮城県。",
    "kana": "ぎゅうたんせんだい、みやぎけん。",
    "romaji": "gyuutan sendai, miyagi ken",
    "zh": "牛舌仙台，宮城縣。"
  },
  {
    "start": 24.5,
    "end": 27.5,
    "text": "なまはげ怖いよ、秋田県。",
    "kana": "なまはげこわいよ、あきたけん。",
    "romaji": "namahage kowai yo, akita ken",
    "zh": "生剝鬼很可怕喔，秋田縣。"
  },
  {
    "start": 27.5,
    "end": 31.5,
    "text": "サクランボおいしい、山形県。",
    "kana": "サクランボおいしい、やまがたけん。",
    "romaji": "sakuranbo oishii, yamagata ken",
    "zh": "櫻桃好吃，山形縣。"
  },
  {
    "start": 31.5,
    "end": 34.5,
    "text": "新選組だぞ、福島県。",
    "kana": "しんせんぐみだぞ、ふくしまけん。",
    "romaji": "shinsengumi da zo, fukushima ken",
    "zh": "是新選組喔，福島縣。"
  },
  {
    "start": 34.5,
    "end": 38.5,
    "text": "お次は関東地方です。",
    "kana": "おつぎはかんとうちほうです。",
    "romaji": "otsugi wa kantou chihou desu",
    "zh": "接著是關東地方。"
  },
  {
    "start": 38.5,
    "end": 41.5,
    "text": "水戸納豆、茨城県。",
    "kana": "みとなっとう、いばらきけん。",
    "romaji": "mito nattou, ibaraki ken",
    "zh": "水戶納豆，茨城縣。"
  },
  {
    "start": 41.5,
    "end": 45.5,
    "text": "餃子宇都宮、栃木県。",
    "kana": "ぎょうざうつのみや、とちぎけん。",
    "romaji": "gyouza utsunomiya, tochigi ken",
    "zh": "餃子宇都宮，栃木縣。"
  },
  {
    "start": 45.5,
    "end": 48.5,
    "text": "利根川前橋、群馬県。",
    "kana": "とねがわまえばし、ぐんまけん。",
    "romaji": "tonegawa maebashi, gunma ken",
    "zh": "利根川前橋，群馬縣。"
  },
  {
    "start": 48.5,
    "end": 52.5,
    "text": "ひらがな さいたま、埼玉県。",
    "kana": "ひらがな さいたま、さいたまけん。",
    "romaji": "hiragana saitama, saitama ken",
    "zh": "平假名的さいたま，埼玉縣。"
  },
  {
    "start": 52.5,
    "end": 55.5,
    "text": "九十九里浜、千葉県です。",
    "kana": "くじゅうくりはま、ちばけんです。",
    "romaji": "kujuukuri hama, chiba ken desu",
    "zh": "九十九里濱，千葉縣。"
  },
  {
    "start": 55.5,
    "end": 59.5,
    "text": "日本の首都だよ、東京都。",
    "kana": "にほんのしゅとだよ、とうきょうと。",
    "romaji": "nihon no shuto da yo, toukyou to",
    "zh": "日本的首都喔，東京都。"
  },
  {
    "start": 59.5,
    "end": 63.5,
    "text": "横浜中華街、神奈川県。",
    "kana": "よこはまちゅうかがい、かながわけん。",
    "romaji": "yokohama chuukagai, kanagawa ken",
    "zh": "橫濱中華街，神奈川縣。"
  },
  {
    "start": 63.5,
    "end": 66.5,
    "text": "中部地方に行きましょう。",
    "kana": "ちゅうぶちほうにいきましょう。",
    "romaji": "chuubu chihou ni ikimashou",
    "zh": "我們去中部地方吧。"
  },
  {
    "start": 66.5,
    "end": 70.5,
    "text": "上杉謙信、新潟県。",
    "kana": "うえすぎけんしん、にいがたけん。",
    "romaji": "uesugi kenshin, niigata ken",
    "zh": "上杉謙信，新潟縣。"
  },
  {
    "start": 70.5,
    "end": 73.5,
    "text": "黒部ダムがある、富山県。",
    "kana": "くろべダムがある、とやまけん。",
    "romaji": "kurobe damu ga aru, toyama ken",
    "zh": "有黑部水壩，富山縣。"
  },
  {
    "start": 73.5,
    "end": 77.5,
    "text": "輪島塗り、金沢、石川県。",
    "kana": "わじまぬり、かなざわ、いしかわけん。",
    "romaji": "wajimanuri, kanazawa, ishikawa ken",
    "zh": "輪島塗、金澤，石川縣。"
  },
  {
    "start": 77.5,
    "end": 80.5,
    "text": "メガネが日本一、福井県。",
    "kana": "メガネがにほんいち、ふくいけん。",
    "romaji": "megane ga nihon ichi, fukui ken",
    "zh": "眼鏡日本第一，福井縣。"
  },
  {
    "start": 80.5,
    "end": 84.5,
    "text": "甲府のぶどう、山梨県。",
    "kana": "こうふのぶどう、やまなしけん。",
    "romaji": "koufu no budou, yamanashi ken",
    "zh": "甲府的葡萄，山梨縣。"
  },
  {
    "start": 84.5,
    "end": 87.5,
    "text": "日本アルプス、長野県。",
    "kana": "にほんアルプス、ながのけん。",
    "romaji": "nihon arupusu, nagano ken",
    "zh": "日本阿爾卑斯，長野縣。"
  },
  {
    "start": 87.5,
    "end": 91.5,
    "text": "白川郷の岐阜県。",
    "kana": "しらかわごうのぎふけん。",
    "romaji": "shirakawagou no gifu ken",
    "zh": "白川鄉，岐阜縣。"
  },
  {
    "start": 91.5,
    "end": 94.5,
    "text": "富士山きれいな、静岡県。",
    "kana": "ふじさんきれいな、しずおかけん。",
    "romaji": "fujisan kirei na, shizuoka ken",
    "zh": "富士山很美，靜岡縣。"
  },
  {
    "start": 94.5,
    "end": 98.5,
    "text": "名古屋コーチン、愛知県。",
    "kana": "なごやコーチン、あいちけん。",
    "romaji": "nagoya koochin, aichi ken",
    "zh": "名古屋交趾雞，愛知縣。"
  },
  {
    "start": 98.5,
    "end": 101.5,
    "text": "近畿地方に行きましょう。",
    "kana": "きんきちほうにいきましょう。",
    "romaji": "kinki chihou ni ikimashou",
    "zh": "我們去近畿地方吧。"
  },
  {
    "start": 101.5,
    "end": 105.5,
    "text": "一文字漢字の津市、三重県。",
    "kana": "ひともじかんじの つし、みえけん。",
    "romaji": "hitomoji kanji no tsu shi, mie ken",
    "zh": "單一漢字的津市，三重縣。"
  },
  {
    "start": 105.5,
    "end": 108.5,
    "text": "大津延暦寺、滋賀県。",
    "kana": "おおつえんりゃくじ、しがけん。",
    "romaji": "ootsu enryakuji, shiga ken",
    "zh": "大津延曆寺，滋賀縣。"
  },
  {
    "start": 108.5,
    "end": 112.5,
    "text": "清水金閣、京都府。",
    "kana": "きよみずきんかく、きょうとふ。",
    "romaji": "kiyomizu kinkaku, kyouto fu",
    "zh": "清水、金閣，京都府。"
  },
  {
    "start": 112.5,
    "end": 115.5,
    "text": "たこ焼きお笑い、大阪府。",
    "kana": "たこやきおわらい、おおさかふ。",
    "romaji": "takoyaki owarai, oosaka fu",
    "zh": "章魚燒搞笑，大阪府。"
  },
  {
    "start": 115.5,
    "end": 119.5,
    "text": "神戸異人館、兵庫県。",
    "kana": "こうべいじんかん、ひょうごけん。",
    "romaji": "koube ijinkan, hyougo ken",
    "zh": "神戶異人館，兵庫縣。"
  },
  {
    "start": 119.5,
    "end": 122.5,
    "text": "鹿と大仏、奈良県。",
    "kana": "しかとだいぶつ、ならけん。",
    "romaji": "shika to daibutsu, nara ken",
    "zh": "鹿和大佛，奈良縣。"
  },
  {
    "start": 122.5,
    "end": 126.5,
    "text": "パンダと梅干し、和歌山県。",
    "kana": "パンダとうめぼし、わかやまけん。",
    "romaji": "panda to umeboshi, wakayama ken",
    "zh": "熊貓和梅干，和歌山縣。"
  },
  {
    "start": 126.5,
    "end": 129.5,
    "text": "次は中国四国地方。",
    "kana": "つぎはちゅうごくしこくちほう。",
    "romaji": "tsugi wa chuugoku shikoku chihou",
    "zh": "接著是中國四國地方。"
  },
  {
    "start": 129.5,
    "end": 133.5,
    "text": "大きな砂丘だ、鳥取県。",
    "kana": "おおきなさきゅうだ、とっとりけん。",
    "romaji": "ookina sakyuu da, tottori ken",
    "zh": "有很大的砂丘，鳥取縣。"
  },
  {
    "start": 133.5,
    "end": 136.5,
    "text": "松江は宍道湖、島根県。",
    "kana": "まつえはしんじこ、しまねけん。",
    "romaji": "matsue wa shinjiko, shimane ken",
    "zh": "松江有宍道湖，島根縣。"
  },
  {
    "start": 136.5,
    "end": 140.5,
    "text": "桃太郎さん、岡山県。",
    "kana": "ももたろうさん、おかやまけん。",
    "romaji": "momotarou san, okayama ken",
    "zh": "桃太郎，岡山縣。"
  },
  {
    "start": 140.5,
    "end": 143.5,
    "text": "生ガキお好み、広島県。",
    "kana": "なまがきおこのみ、ひろしまけん。",
    "romaji": "namagaki okonomi, hiroshima ken",
    "zh": "生蠔、廣島燒，廣島縣。"
  },
  {
    "start": 143.5,
    "end": 146.5,
    "text": "ふぐちりてっさの、山口県。",
    "kana": "ふぐちりてっさの、やまぐちけん。",
    "romaji": "fuguchiri tessa no, yamaguchi ken",
    "zh": "河豚火鍋、河豚生魚片，山口縣。"
  },
  {
    "start": 146.5,
    "end": 150.5,
    "text": "阿波踊りをする、徳島県。",
    "kana": "あわおどりをする、とくしまけん。",
    "romaji": "awa odori o suru, tokushima ken",
    "zh": "會跳阿波舞，德島縣。"
  },
  {
    "start": 150.5,
    "end": 153.5,
    "text": "うどんと高松、香川県。",
    "kana": "うどんとたかまつ、かがわけん。",
    "romaji": "udon to takamatsu, kagawa ken",
    "zh": "烏龍麵和高松，香川縣。"
  },
  {
    "start": 153.5,
    "end": 157.5,
    "text": "みかんだ松山、愛媛県。",
    "kana": "みかんだまつやま、えひめけん。",
    "romaji": "mikan da matsuyama, ehime ken",
    "zh": "蜜柑的松山，愛媛縣。"
  },
  {
    "start": 157.5,
    "end": 160.5,
    "text": "坂本龍馬の、高知県。",
    "kana": "さかもとりょうまの、こうちけん。",
    "romaji": "sakamoto ryouma no, kochi ken",
    "zh": "坂本龍馬的高知縣。"
  },
  {
    "start": 160.5,
    "end": 164.5,
    "text": "九州地方に行きますよ。",
    "kana": "きゅうしゅうちほうにいきますよ。",
    "romaji": "kyuushuu chihou ni ikimasu yo",
    "zh": "接著要去九州地方囉。"
  },
  {
    "start": 164.5,
    "end": 167.5,
    "text": "明太子大好き、福岡県。",
    "kana": "めんたいこだいすき、ふくおかけん。",
    "romaji": "mentaiko daisuki, fukuoka ken",
    "zh": "最喜歡明太子，福岡縣。"
  },
  {
    "start": 167.5,
    "end": 171.5,
    "text": "有田と伊万里焼き、佐賀県。",
    "kana": "ありたといまりやき、さがけん。",
    "romaji": "arita to imariyaki, saga ken",
    "zh": "有田燒與伊萬里燒，佐賀縣。"
  },
  {
    "start": 171.5,
    "end": 175.5,
    "text": "カステラちゃんぽん、長崎県。",
    "kana": "カステラちゃんぽん、ながさきけん。",
    "romaji": "kasutera chanpon, nagasaki ken",
    "zh": "蛋糕、強棒麵，長崎縣。"
  },
  {
    "start": 175.5,
    "end": 178.5,
    "text": "ラーメン阿蘇山、熊本県。",
    "kana": "ラーメンあそさん、くまもとけん。",
    "romaji": "raamen asosan, kumamoto ken",
    "zh": "拉麵、阿蘇山，熊本縣。"
  },
  {
    "start": 178.5,
    "end": 182.5,
    "text": "温泉行きたい、大分県。",
    "kana": "おんせんいきたい、おおいたけん。",
    "romaji": "onsen ikitai, ooita ken",
    "zh": "想去泡溫泉，大分縣。"
  },
  {
    "start": 182.5,
    "end": 185.5,
    "text": "マンゴー輝く、宮崎県。",
    "kana": "マンゴーかがやく、みやざきけん。",
    "romaji": "mangoo kagayaku, miyazaki ken",
    "zh": "芒果閃耀，宮崎縣。"
  },
  {
    "start": 185.5,
    "end": 189.5,
    "text": "桜島もくもく、鹿児島県。",
    "kana": "さくらじまもくもく、かごしまけん。",
    "romaji": "sakurajima mokumoku, kagoshima ken",
    "zh": "櫻島煙霧滾滾，鹿兒島縣。"
  },
  {
    "start": 189.5,
    "end": 192.5,
    "text": "那覇は南国、沖縄県。",
    "kana": "なははなんごく、おきなわけん。",
    "romaji": "naha wa nangoku, okinawa ken",
    "zh": "那霸是南國，沖繩縣。"
  },
  {
    "start": 192.5,
    "end": 195.5,
    "text": "四十七個の都道府県。",
    "kana": "よんじゅうななこのとどうふけん。",
    "romaji": "yonjuu nana ko no todoufuken",
    "zh": "四十七個都道府縣。"
  }
]